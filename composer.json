{
    "name": "psc-acme/parser-catalog",
    "description": "Package parser-catalog for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ParserCatalog\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "symfony/symfony": "^6.3",
        "symfony/event-dispatcher": "^7.0",
        "symfony/yaml": "^7.0",
        "ramsey/uuid": "^4.0",
        "guzzlehttp/guzzle": "^7.0",
        "psc-acme/worker-cart": "^1.0",
        "psc-acme/driver-product": "^1.0"
    },
    "require-dev": {
        "vimeo/psalm": "^5.0"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}